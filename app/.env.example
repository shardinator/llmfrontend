# Copy to `.env.local` for overrides (gitignored). `.env.development` is committed for defaults.

# --- Local dev: Vite /api proxy target only (ignored for browser fetch while `vite dev` runs). ---
BACKEND_URL=http://127.0.0.1:8080

# --- Vercel / production build: same BACKEND_URL is read at build time for browser → API (or use VITE_API_BASE). ---
# BACKEND_URL=https://your-backend.fly.dev

# --- Or compose proxy target (used if BACKEND_URL / VITE_API_BASE are unset) ---
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8080
# Same as backend `PORT` when you only set one port for both:
# PORT=8080

# Optional aliases (see vite.config.ts resolution order)
# VITE_API_HOST=127.0.0.1
# VITE_API_PORT=8080
# VITE_BACKEND_PORT=8080

# --- Alternative production name (same as BACKEND_URL on Vercel) ---
# VITE_API_BASE=https://your-backend.fly.dev

# --- Direct browser → API (optional; skips /api proxy — needs CORS on the backend) ---
# VITE_API_PROTOCOL=http
# VITE_API_HOST=127.0.0.1
# VITE_API_PORT=8080
